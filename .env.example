# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# Found in: RevenueCat dashboard → Project Settings → API Keys
# iOS (App Store) public SDK key — prefix: appl_
REVENUECAT_API_KEY_APPLE=appl_your_ios_key_here
# Android (Google Play) public SDK key — prefix: goog_
REVENUECAT_API_KEY_GOOGLE=goog_your_android_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://yachtwatch.co
